<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Guide"
            android:textColor="@color/text_dark"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="How to Use Explit"
            android:textColor="@color/text_dark"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="1. Create a Group\nGo to the 'New Group' navigation tab, just besides the 'Home' tab to create a group. Enter a name, select a category, and add participants. Press 'Save Group' when done.\n\n2. Add an Event\nInside a group, tap 'Add Event'. Give it a name, select a category, and choose which participants are involved.\n\n3. Add Items &amp; Receipts\nEnter the total bill amount first, then add individual items. Assign each item to the people who shared it. You can also add receipt photos.\n\n4. Select Payers\nTap 'Select Payer' to choose who paid. You can select multiple people and enter how much each paid. The total must match the bill.\n\n5. Calculate Split\nOnce all items match the bill total, tap 'Calculate &amp; Split' to see the settlement summary.\n\n6. Record Payments\nIn the settlement summary, tap a payment to record partial or full payments. The status updates in real time."
            android:textColor="@color/text_dark"
            android:textSize="14sp"
            android:lineSpacingExtra="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Color Indicators"
            android:textColor="@color/text_dark"
            android:textSize="18sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <View
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:background="#FFFFF9C4"
                android:layout_marginEnd="12dp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Light Yellow — Event is incomplete (subtotal doesn't match bill total)"
                android:textColor="@color/text_dark"
                android:textSize="14sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <View
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:background="#FFFFEBEE"
                android:layout_marginEnd="12dp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Light Red — Event has unpaid settlements"
                android:textColor="@color/text_dark"
                android:textSize="14sp" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Preferences"
            android:textColor="@color/text_dark"
            android:textSize="18sp"
            android:textStyle="bold" />

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.Explit.CardView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="8dp">

                <LinearLayout
                    android:id="@+id/row_conversion"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:padding="12dp"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Conversion"
                        android:textColor="@color/text_dark" />

                    <TextView
                        android:id="@+id/text_conversion_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Keep Decimals"
                        android:textColor="@color/primary" />
                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_gravity="center"
            android:text="Version 1.0.0"
            android:textColor="@color/text_light"
            android:textSize="12sp" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>